# Nightshift AI - Email Ingestion Configuration
# ================================================
# Copy this file to .env and fill in your credentials.
#
# For Outlook / Office 365:
#   1. Enable 2-Factor Authentication on your Microsoft account
#   2. Go to https://account.microsoft.com/security
#   3. Create an App Password under "Additional security options"
#   4. Paste the generated password below
#
# For Gmail (if switching from Outlook):
#   Change IMAP/SMTP servers to imap.gmail.com / smtp.gmail.com
#   Create App Password at https://myaccount.google.com/apppasswords

EMAIL_ADDRESS=your-email@outlook.com
EMAIL_APP_PASSWORD=your-app-password-here

# Server settings (defaults are for Outlook/O365)
EMAIL_IMAP_SERVER=outlook.office365.com
EMAIL_SMTP_SERVER=smtp.office365.com

# Folder to monitor
EMAIL_WATCH_FOLDER=INBOX

# How often to check for new emails (seconds)
EMAIL_POLL_INTERVAL=60

# Only process emails with this text in the subject (leave blank for all)
EMAIL_SUBJECT_FILTER=

# Optional: override the Claude API key (otherwise uses hardcoded value in config.py)
# CLAUDE_API_KEY=sk-ant-...
